APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

## Database - change to mysql for production
DB_CONNECTION=mysql
# Example Aiven / production values (override in production env or Render secrets)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ecap_laravel
DB_USERNAME=avnadmin
DB_PASSWORD=

# If your MySQL requires an SSL CA file (Aiven), set the container path below
# In containers use: MYSQL_ATTR_SSL_CA=/var/www/html/storage/certs/ca.pem
MYSQL_ATTR_SSL_CA=
# AIVEN_CA_PEM: (optional) the full CA PEM text. For Render, add this as a secret
# and the entrypoint will write it to the path above.
AIVEN_CA_PEM=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Switch to 's3' and add AWS credentials for persistent object storage on Render
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Optional runtime flags
# If set to 'true' the container entrypoint will attempt to run migrations on start
# (use with caution in production). Default: false
RUN_MIGRATIONS=false
